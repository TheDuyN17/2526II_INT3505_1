# Sao chép file này thành .env và điền giá trị thực tế
# cp .env.example .env

# MongoDB connection string
# Local:   mongodb://localhost:27017/product_db
# Atlas:   mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/product_db
MONGODB_URI=mongodb://localhost:27017/product_db

# Server port (mặc định: 8080)
PORT=8080

# Môi trường: development | production
FLASK_ENV=development
